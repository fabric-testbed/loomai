# .weaveignore — files excluded from publishing
# Uses .gitignore-style patterns. One pattern per line.
# Built-in defaults always apply: __pycache__, *.pyc, .git, .env, *.log

# Data and results (regenerated by running the weave)
data/
results/
output/
*.csv
*.json.gz

# Credentials and secrets
*.key
*.pem
secrets/
.ssh/

# Jupyter notebook outputs (clear before publishing)
.ipynb_checkpoints/

# OS and editor files
.DS_Store
Thumbs.db
*.swp
*.swo
*~
